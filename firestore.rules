rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin status comes from the `admin` custom claim, kept in sync with
    // users/{uid}.role by the syncAdminClaim Cloud Function. The claim is
    // already in request.auth.token, so rules don't need any cross-doc reads.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /users/{userId} {
      allow read: if true;
      // Self-signup creates the doc with the user's own uid.
      allow create: if isSignedIn() && request.auth.uid == userId;
      // A user can update their own doc; admins can update any user doc
      // (needed for the admin panel to change roles, etc.).
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /creators/{creatorId} {
      allow read: if true;
      // Admins can write any creator doc.
      // A creator (role = 'creator') can write only their own doc, where the
      // doc id matches their uid.
      // Anyone may bump the public view counter, but ONLY the `views` field —
      // no other field can change in the same write. Powers the dashboard's
      // "most visited" metric without exposing the rest of the doc.
      allow create, update: if isAdmin()
        || (isSignedIn() && request.auth.uid == creatorId)
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Categories taxonomy — public read (so home/filters/picker render),
    // admin-only write (managed from /admin/categories).
    match /taxonomy/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Event RSVPs — one document per (event, user). Doc id is
    // `{creatorId}_{eventIdx}_{userId}` so the system stays simple (no
    // subcollections, dedupe is implicit). Anyone can read counts; only the
    // owner of the RSVP (matching userId in the doc) can create/update/delete.
    match /rsvps/{rsvpId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // Posts — wall/feed content authored by a creator (shop) or a user.
    // authorId must be the signed-in user on create; only the author can
    // edit/delete. Public read (the feed). likesCount is maintained by a
    // trigger (admin SDK), so client writes never set it directly.
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;
    }

    // Follows — one document per (follower, followee). Doc id is
    // `{followerId}_{followeeId}`. followerId is always the signed-in user;
    // followeeType ("creator" | "user") records WHAT is followed so triggers
    // and queries know which collection it belongs to (it is NOT a
    // "followed-or-not" flag — that's just whether this doc exists). Public
    // read (follower counts / "following" lists); only the follower may
    // create/delete their own follow. No update — a follow only exists or not.
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.followerId == request.auth.uid;
    }

    // Likes (the ♥). One doc per (user, target). Doc id is
    // `{userId}_{targetType}_{targetId}`. targetType ("post" | "creator" |
    // "user") selects the collection whose likesCount a trigger maintains.
    // Public read (counts); only the liker can create/delete their own like.
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }
  }
}
